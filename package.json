{
  "name": "explain-panel-kit",
  "version": "1.0.0",
  "description": "Two Claude Code skills (/explore-pipeline + /explain-panel) that turn any codebase into a syntax-highlighted, annotated accordion documentation component for React/Next.js or Vue/Nuxt.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sofiane-git/explain-panel-kit.git"
  },
  "homepage": "https://github.com/sofiane-git/explain-panel-kit#readme",
  "bugs": {
    "url": "https://github.com/sofiane-git/explain-panel-kit/issues"
  },
  "keywords": [
    "claude-code",
    "claude-skill",
    "documentation",
    "code-walkthrough",
    "explain-panel",
    "rag",
    "nextjs",
    "nuxt"
  ],
  "files": [
    "skills/**",
    "schemas/**",
    "migrate/**",
    "plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "validate:schema": "ajv validate --spec=draft2020 -s schemas/pipeline-map.schema.json -d 'examples/*/docs/pipeline-map.json'",
    "validate:plugin": "ajv validate --spec=draft2020 -s plugin.json -d plugin.json --strict=false || true"
  },
  "devDependencies": {
    "ajv-cli": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
