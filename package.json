{
  "name": "explain-panel-skills",
  "version": "1.0.0",
  "description": "Two Claude Code skills (/explore-pipeline + /explain-panel) that turn any codebase into a syntax-highlighted, annotated accordion documentation component for React/Next.js, Vue/Nuxt, or a self-contained HTML file (zero runtime deps, auto-fallback for backend-only projects).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sofiane-git/explain-panel-skills.git"
  },
  "homepage": "https://github.com/sofiane-git/explain-panel-skills#readme",
  "bugs": {
    "url": "https://github.com/sofiane-git/explain-panel-skills/issues"
  },
  "keywords": [
    "claude-code",
    "claude-skill",
    "claude-plugin",
    "docpanel",
    "documentation",
    "code-walkthrough",
    "explain-panel",
    "rag",
    "nextjs",
    "nuxt",
    "html-standalone",
    "backend-only"
  ],
  "files": [
    ".claude-plugin/**",
    "skills/**",
    "schemas/**",
    "migrate/**",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "validate:schema": "ajv validate --spec=draft2020 -s schemas/pipeline-map.schema.json -d 'examples/*/docs/pipeline-map.json'"
  },
  "devDependencies": {
    "ajv-cli": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
