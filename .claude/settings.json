{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-main.sh\"",
            "timeout": 10,
            "statusMessage": "Checking branch protection rule"
          }
        ]
      }
    ]
  }
}
